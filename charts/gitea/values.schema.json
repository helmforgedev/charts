{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Gitea Helm Chart Values",
  "description": "Values schema for the HelmForge Gitea chart.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "description": "Gitea container image settings.",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository."
        },
        "tag": {
          "type": "string",
          "description": "Image tag (defaults to appVersion-rootless)."
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy.",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets."
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the release name."
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name."
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of replicas.",
      "minimum": 1
    },
    "gitea": {
      "type": "object",
      "description": "Gitea application settings.",
      "properties": {
        "appName": {
          "type": "string",
          "description": "Application display name."
        },
        "runMode": {
          "type": "string",
          "description": "Run mode: dev, prod, test.",
          "enum": ["dev", "prod", "test"]
        },
        "rootUrl": {
          "type": "string",
          "description": "Root URL for Gitea."
        },
        "sshDomain": {
          "type": "string",
          "description": "SSH domain shown in clone URLs."
        },
        "sshPort": {
          "type": "integer",
          "description": "SSH listen port."
        },
        "lfsEnabled": {
          "type": "boolean",
          "description": "Enable Git LFS."
        },
        "disableRegistration": {
          "type": "boolean",
          "description": "Disable user self-registration."
        },
        "requireSignIn": {
          "type": "boolean",
          "description": "Require sign-in to view any page."
        },
        "extraEnv": {
          "type": "array",
          "description": "Extra environment variables."
        }
      }
    },
    "admin": {
      "type": "object",
      "description": "Admin user configuration.",
      "properties": {
        "username": {
          "type": "string",
          "description": "Admin username."
        },
        "password": {
          "type": "string",
          "description": "Admin password."
        },
        "email": {
          "type": "string",
          "description": "Admin email."
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret with admin credentials."
        }
      }
    },
    "database": {
      "type": "object",
      "description": "Database configuration.",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Database mode: auto | sqlite | external | postgresql | mysql.",
          "enum": ["auto", "sqlite", "external", "postgresql", "mysql"]
        },
        "sqlite": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "SQLite database file path."
            }
          }
        },
        "external": {
          "type": "object",
          "description": "External database configuration.",
          "properties": {
            "vendor": {
              "type": "string",
              "description": "Database vendor: postgres | mysql.",
              "enum": ["postgres", "mysql"]
            },
            "host": {
              "type": "string",
              "description": "External database hostname."
            },
            "port": {
              "type": ["string", "integer"],
              "description": "External database port."
            },
            "name": {
              "type": "string",
              "description": "Database name."
            },
            "username": {
              "type": "string",
              "description": "Database username."
            },
            "password": {
              "type": "string",
              "description": "Database password."
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret for database password."
            },
            "existingSecretPasswordKey": {
              "type": "string",
              "description": "Key in the existing secret."
            }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "description": "PostgreSQL subchart configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy PostgreSQL as a subchart."
        },
        "architecture": {
          "type": "string",
          "description": "PostgreSQL architecture.",
          "enum": ["standalone", "replication"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "rootPassword": { "type": "string" }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "mysql": {
      "type": "object",
      "description": "MySQL subchart configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy MySQL as a subchart."
        },
        "architecture": {
          "type": "string",
          "description": "MySQL architecture.",
          "enum": ["standalone", "replication"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "rootPassword": { "type": "string" }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistent storage for Gitea data.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable persistent storage." },
        "storageClass": { "type": "string", "description": "Storage class." },
        "accessMode": { "type": "string", "description": "PVC access mode." },
        "size": { "type": "string", "description": "Volume size." },
        "existingClaim": { "type": "string", "description": "Existing PVC name." },
        "annotations": { "type": "object", "description": "PVC annotations." }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory resources."
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod security context."
    },
    "securityContext": {
      "type": "object",
      "description": "Container security context."
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe configuration."
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration."
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration."
    },
    "service": {
      "type": "object",
      "description": "Service configuration.",
      "properties": {
        "http": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer" },
            "annotations": { "type": "object" },
            "ipFamilyPolicy": { "type": ["string", "null"], "description": "Dual-stack ipFamilyPolicy (GR-058)", "enum": [null, "SingleStack", "PreferDualStack", "RequireDualStack"] },
            "ipFamilies": { "type": "array", "description": "Dual-stack ipFamilies (GR-058)", "items": { "type": "string", "enum": ["IPv4", "IPv6"] }, "maxItems": 2 }
          }
        },
        "ssh": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer" },
            "nodePort": { "type": ["string", "integer"] },
            "annotations": { "type": "object" },
            "ipFamilyPolicy": { "type": ["string", "null"], "description": "Dual-stack ipFamilyPolicy (GR-058)", "enum": [null, "SingleStack", "PreferDualStack", "RequireDualStack"] },
            "ipFamilies": { "type": "array", "description": "Dual-stack ipFamilies (GR-058)", "items": { "type": "string", "enum": ["IPv4", "IPv6"] }, "maxItems": 2 }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration.",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressClassName": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration.",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "backup": {
      "type": "object",
      "description": "S3 backup CronJob configuration.",
      "properties": {
        "enabled": { "type": "boolean" },
        "schedule": { "type": "string" },
        "suspend": { "type": "boolean" },
        "concurrencyPolicy": { "type": "string", "enum": ["Forbid", "Replace", "Allow"] },
        "successfulJobsHistoryLimit": { "type": "integer" },
        "failedJobsHistoryLimit": { "type": "integer" },
        "backoffLimit": { "type": "integer" },
        "archivePrefix": { "type": "string" },
        "images": { "type": "object" },
        "resources": { "type": "object" },
        "s3": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "bucket": { "type": "string" },
            "prefix": { "type": "string" },
            "createBucketIfNotExists": { "type": "boolean" },
            "existingSecret": { "type": "string" },
            "existingSecretAccessKeyKey": { "type": "string" },
            "existingSecretSecretKeyKey": { "type": "string" },
            "accessKey": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "database": { "type": "object" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "extraManifests": { "type": "array" },
    "gateway": {
      "type": "object",
      "description": "Gateway API HTTPRoute configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "annotations": { "type": "object" },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "path": { "type": "string", "default": "/" },
        "pathType": { "type": "string", "enum": ["PathPrefix", "Exact", "RegularExpression"], "default": "PathPrefix" }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "apiVersion": { "type": "string", "default": "external-secrets.io/v1" },
        "refreshInterval": { "type": "string", "default": "1h" },
        "secretStoreRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string" }
          }
        },
        "target": {
          "type": "object",
          "properties": {
            "creationPolicy": { "type": "string" }
          }
        },
        "data": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
