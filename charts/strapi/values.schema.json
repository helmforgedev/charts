{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Strapi Helm Chart",
  "description": "Headless CMS for APIs, websites, and custom admin experiences.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names."
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource names."
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to every resource created by this chart."
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of replicas. Multi-replica requires S3/Cloudinary upload provider.",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "description": "Container image configuration.",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository for your Strapi project."
        },
        "tag": {
          "type": "string",
          "description": "Container image tag (defaults to appVersion when empty)."
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy.",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries.",
      "items": {
        "type": "object"
      }
    },
    "strapi": {
      "type": "object",
      "description": "Strapi application configuration.",
      "properties": {
        "host": {
          "type": "string",
          "description": "Host interface."
        },
        "port": {
          "type": "integer",
          "description": "Container port exposed by Strapi."
        },
        "url": {
          "type": "string",
          "description": "Public URL of the Strapi instance (auto-detected from ingress if empty)."
        },
        "nodeEnv": {
          "type": "string",
          "description": "Node environment.",
          "enum": ["production", "development"]
        },
        "telemetryDisabled": {
          "type": "boolean",
          "description": "Disable telemetry."
        },
        "command": {
          "type": "array",
          "description": "Start command override.",
          "items": {
            "type": "string"
          }
        },
        "args": {
          "type": "array",
          "description": "Start arguments override.",
          "items": {
            "type": "string"
          }
        },
        "extraEnv": {
          "type": "array",
          "description": "Additional environment variables for the Strapi container.",
          "items": {
            "type": "object"
          }
        },
        "upload": {
          "type": "object",
          "properties": {
            "provider": { "type": "string", "enum": ["local", "aws-s3", "cloudinary"] },
            "s3": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "endpoint": { "type": "string" },
                "region": { "type": "string" },
                "bucket": { "type": "string" },
                "prefix": { "type": "string" },
                "existingSecret": { "type": "string" },
                "existingSecretAccessKeyKey": { "type": "string" },
                "existingSecretSecretKeyKey": { "type": "string" },
                "accessKey": { "type": "string" },
                "secretKey": { "type": "string" },
                "acl": { "type": "string" },
                "baseUrl": { "type": "string" },
                "params": { "type": "object" }
              }
            },
            "cloudinary": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "cloudName": { "type": "string" },
                "apiKey": { "type": "string" },
                "apiSecret": { "type": "string" },
                "existingSecret": { "type": "string" },
                "existingSecretApiKeyKey": { "type": "string" },
                "existingSecretApiSecretKey": { "type": "string" }
              }
            }
          }
        },
        "performance": {
          "type": "object",
          "properties": {
            "nodeOptions": { "type": "string" },
            "logLevel": { "type": "string", "enum": ["fatal", "error", "warn", "info", "debug", "trace"] },
            "prettyPrint": { "type": "boolean" },
            "forceJsonLogs": { "type": "boolean" }
          }
        },
        "admin": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "autoOpen": { "type": "boolean" },
            "jwtExpiration": { "type": "string" },
            "rateLimit": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "max": { "type": "integer" },
                "timeWindow": { "type": "integer" }
              }
            },
            "forgotPassword": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "email": {
          "type": "object",
          "properties": {
            "provider": { "type": "string", "enum": ["none", "smtp", "sendgrid"] },
            "defaultFrom": { "type": "string" },
            "defaultReplyTo": { "type": "string" },
            "smtp": {
              "type": "object",
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer" },
                "username": { "type": "string" },
                "password": { "type": "string" },
                "existingSecret": { "type": "string" },
                "existingSecretPasswordKey": { "type": "string" },
                "secure": { "type": "boolean" },
                "requireTLS": { "type": "boolean" },
                "ignoreTLS": { "type": "boolean" }
              }
            },
            "sendgrid": {
              "type": "object",
              "properties": {
                "apiKey": { "type": "string" },
                "existingSecret": { "type": "string" },
                "existingSecretApiKeyKey": { "type": "string" }
              }
            }
          }
        },
        "graphql": {
          "type": "object",
          "properties": {
            "playgroundEnabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "introspection": { "type": "boolean" },
            "maxDepth": { "type": "integer" },
            "maxComplexity": { "type": "integer" },
            "apolloSandbox": { "type": "boolean" }
          }
        },
        "api": {
          "type": "object",
          "properties": {
            "rest": {
              "type": "object",
              "properties": {
                "defaultLimit": { "type": "integer" },
                "maxLimit": { "type": "integer" }
              }
            }
          }
        },
        "server": {
          "type": "object",
          "properties": {
            "bodyParser": {
              "type": "object",
              "properties": {
                "jsonLimit": { "type": "string" },
                "formLimit": { "type": "string" },
                "textLimit": { "type": "string" }
              }
            },
            "compression": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            },
            "cron": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            },
            "logger": {
              "type": "object",
              "properties": {
                "level": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Application secrets (APP_KEYS, API_TOKEN_SALT, etc.). Auto-generated if not provided.",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Use an existing secret containing all Strapi app secrets."
        },
        "existingSecretAppKeysKey": {
          "type": "string",
          "description": "Existing secret key for APP_KEYS (comma-separated)."
        },
        "existingSecretApiTokenSaltKey": {
          "type": "string",
          "description": "Existing secret key for API token salt."
        },
        "existingSecretAdminJwtSecretKey": {
          "type": "string",
          "description": "Existing secret key for admin JWT secret."
        },
        "existingSecretJwtSecretKey": {
          "type": "string",
          "description": "Existing secret key for application JWT secret."
        },
        "existingSecretTransferTokenSaltKey": {
          "type": "string",
          "description": "Existing secret key for transfer token salt."
        },
        "appKeys": {
          "type": "string",
          "description": "Explicit APP_KEYS value (comma-separated). Auto-generated if empty."
        },
        "apiTokenSalt": {
          "type": "string",
          "description": "Explicit API token salt. Auto-generated if empty."
        },
        "adminJwtSecret": {
          "type": "string",
          "description": "Explicit admin JWT secret. Auto-generated if empty."
        },
        "jwtSecret": {
          "type": "string",
          "description": "Explicit application JWT secret. Auto-generated if empty."
        },
        "transferTokenSalt": {
          "type": "string",
          "description": "Explicit transfer token salt. Auto-generated if empty."
        }
      }
    },
    "database": {
      "type": "object",
      "description": "Database configuration. Supports SQLite, PostgreSQL, and MySQL.",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Database mode: auto | sqlite | external | postgresql | mysql.",
          "enum": ["auto", "sqlite", "external", "postgresql", "mysql"]
        },
        "sqlite": {
          "type": "object",
          "properties": {
            "directory": {
              "type": "string",
              "description": "Directory mounted for the SQLite database file."
            },
            "filename": {
              "type": "string",
              "description": "SQLite database filename."
            }
          }
        },
        "external": {
          "type": "object",
          "description": "External database configuration.",
          "properties": {
            "vendor": {
              "type": "string",
              "description": "External database vendor: postgres | mysql.",
              "enum": ["postgres", "mysql"]
            },
            "host": {
              "type": "string",
              "description": "External database hostname."
            },
            "port": {
              "type": ["string", "integer"],
              "description": "External database port (auto-detected from vendor if empty)."
            },
            "name": {
              "type": "string",
              "description": "Database name."
            },
            "username": {
              "type": "string",
              "description": "Database username."
            },
            "password": {
              "type": "string",
              "description": "Database password (ignored when existingSecret is set)."
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret for the database password."
            },
            "existingSecretPasswordKey": {
              "type": "string",
              "description": "Key in the existing secret for the database password."
            },
            "ssl": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Set DATABASE_SSL=true."
                }
              }
            }
          }
        },
        "pool": {
          "type": "object",
          "description": "Database connection pooling configuration.",
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 0,
              "description": "Minimum database connections per replica."
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum database connections per replica."
            },
            "acquireTimeoutMillis": {
              "type": "integer",
              "description": "Connection acquisition timeout (ms)."
            },
            "idleTimeoutMillis": {
              "type": "integer",
              "description": "Idle connection timeout (ms)."
            }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "description": "PostgreSQL subchart configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy PostgreSQL as a subchart."
        },
        "architecture": {
          "type": "string",
          "description": "PostgreSQL architecture (standalone or replication)."
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": {
              "type": "string",
              "description": "Database name created on first run."
            },
            "username": {
              "type": "string",
              "description": "Database username created on first run."
            },
            "password": {
              "type": "string",
              "description": "Database password (auto-generated if empty)."
            },
            "rootPassword": {
              "type": "string",
              "description": "Root password (auto-generated if empty)."
            }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable persistence for PostgreSQL data."
                },
                "size": {
                  "type": "string",
                  "description": "PVC size for PostgreSQL."
                }
              }
            }
          }
        }
      }
    },
    "mysql": {
      "type": "object",
      "description": "MySQL subchart configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy MySQL as a subchart."
        },
        "architecture": {
          "type": "string",
          "description": "MySQL architecture (standalone or replication)."
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": {
              "type": "string",
              "description": "Database name created on first run."
            },
            "username": {
              "type": "string",
              "description": "Database username created on first run."
            },
            "password": {
              "type": "string",
              "description": "Database password (auto-generated if empty)."
            },
            "rootPassword": {
              "type": "string",
              "description": "Root password (auto-generated if empty)."
            }
          }
        },
        "primary": {
          "type": "object",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable persistence for MySQL data."
                },
                "size": {
                  "type": "string",
                  "description": "PVC size for MySQL."
                }
              }
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistent storage for uploads and SQLite data.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable persistent storage for uploads and SQLite data."
        },
        "storageClass": {
          "type": "string",
          "description": "Storage class (leave empty for cluster default)."
        },
        "accessMode": {
          "type": "string",
          "description": "Access mode for the PVC."
        },
        "size": {
          "type": "string",
          "description": "Size of the persistent volume."
        },
        "existingClaim": {
          "type": "string",
          "description": "Use an existing PVC instead of creating one."
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the PVC."
        },
        "uploads": {
          "type": "object",
          "properties": {
            "mountPath": {
              "type": "string",
              "description": "Uploads directory inside the Strapi container."
            },
            "subPath": {
              "type": "string",
              "description": "PVC subPath used for uploads data."
            }
          }
        },
        "sqlite": {
          "type": "object",
          "properties": {
            "subPath": {
              "type": "string",
              "description": "PVC subPath used for SQLite data."
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory requests/limits for the Strapi container."
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context."
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context."
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe configuration.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable startup probe." },
        "initialDelaySeconds": { "type": "integer" },
        "periodSeconds": { "type": "integer" },
        "timeoutSeconds": { "type": "integer" },
        "failureThreshold": { "type": "integer" }
      }
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable liveness probe." },
        "initialDelaySeconds": { "type": "integer" },
        "periodSeconds": { "type": "integer" },
        "timeoutSeconds": { "type": "integer" },
        "failureThreshold": { "type": "integer" }
      }
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable readiness probe." },
        "initialDelaySeconds": { "type": "integer" },
        "periodSeconds": { "type": "integer" },
        "timeoutSeconds": { "type": "integer" },
        "failureThreshold": { "type": "integer" }
      }
    },
    "service": {
      "type": "object",
      "description": "Service configuration.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type.",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "description": "HTTP port exposed by the Service."
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the service."
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration for Strapi.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ingress for Strapi."
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name."
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations."
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts.",
          "items": { "type": "object" }
        },
        "tls": {
          "type": "array",
          "description": "Ingress TLS configuration.",
          "items": { "type": "object" }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration.",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a dedicated ServiceAccount."
        },
        "name": {
          "type": "string",
          "description": "Name override (auto-generated if empty)."
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the ServiceAccount."
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Scheduled backups to S3-compatible storage.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable scheduled backups to S3-compatible storage."
        },
        "schedule": {
          "type": "string",
          "description": "Cron schedule for backups (default: daily at 03:00 UTC)."
        },
        "suspend": {
          "type": "boolean",
          "description": "Suspend the CronJob without deleting it."
        },
        "concurrencyPolicy": {
          "type": "string",
          "description": "Concurrency policy: Forbid, Replace, Allow.",
          "enum": ["Forbid", "Replace", "Allow"]
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "description": "Number of successful job records to keep."
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "description": "Number of failed job records to keep."
        },
        "backoffLimit": {
          "type": "integer",
          "description": "Maximum retries per backup job."
        },
        "archivePrefix": {
          "type": "string",
          "description": "Prefix for backup archive filenames."
        },
        "images": {
          "type": "object",
          "description": "Container images used by backup jobs.",
          "properties": {
            "utility": {
              "type": "string",
              "description": "Image used for local file backup jobs (must have tar)."
            },
            "postgresql": {
              "type": "string",
              "description": "Image used for PostgreSQL backup (must have pg_dump)."
            },
            "mysql": {
              "type": "string",
              "description": "Image used for MySQL backup (must have mysqldump)."
            },
            "uploader": {
              "type": "string",
              "description": "Image used for S3 upload (MinIO client)."
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for backup containers."
        },
        "s3": {
          "type": "object",
          "description": "S3-compatible storage configuration for backups.",
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "S3-compatible endpoint URL."
            },
            "bucket": {
              "type": "string",
              "description": "Target bucket name."
            },
            "prefix": {
              "type": "string",
              "description": "Key prefix within the bucket."
            },
            "createBucketIfNotExists": {
              "type": "boolean",
              "description": "Auto-create the bucket if it does not exist."
            },
            "existingSecret": {
              "type": "string",
              "description": "Use an existing secret for S3 credentials."
            },
            "existingSecretAccessKeyKey": {
              "type": "string",
              "description": "Key in the existing secret for the access key."
            },
            "existingSecretSecretKeyKey": {
              "type": "string",
              "description": "Key in the existing secret for the secret key."
            },
            "accessKey": {
              "type": "string",
              "description": "Inline S3 access key (ignored when existingSecret is set)."
            },
            "secretKey": {
              "type": "string",
              "description": "Inline S3 secret key (ignored when existingSecret is set)."
            }
          }
        },
        "database": {
          "type": "object",
          "description": "Override database credentials for backup (uses app credentials if empty).",
          "properties": {
            "host": { "type": "string", "description": "Override database host for backup." },
            "port": { "type": ["string", "integer"], "description": "Override database port for backup." },
            "name": { "type": "string", "description": "Override database name for backup." },
            "username": { "type": "string", "description": "Override database username for backup." },
            "existingSecret": { "type": "string", "description": "Existing secret for backup database credentials." },
            "existingSecretPasswordKey": { "type": "string", "description": "Key in existing secret for the backup database password." },
            "postgresDumpArgs": { "type": "string", "description": "Extra arguments for pg_dump." },
            "mysqlDumpArgs": { "type": "string", "description": "Extra arguments for mysqldump." }
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling."
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling.",
      "items": { "type": "object" }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod scheduling."
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints.",
      "items": { "type": "object" }
    },
    "priorityClassName": {
      "type": "string",
      "description": "Priority class name."
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Grace period for shutdown (seconds)."
    },
    "podLabels": {
      "type": "object",
      "description": "Additional labels for the pod."
    },
    "podAnnotations": {
      "type": "object",
      "description": "Additional annotations for the pod."
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts for the Strapi container.",
      "items": { "type": "object" }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes for the pod.",
      "items": { "type": "object" }
    },
    "extraManifests": {
      "type": "array",
      "description": "Extra Kubernetes manifests to deploy alongside the chart.",
      "items": { "type": "object" }
    }
  }
}
