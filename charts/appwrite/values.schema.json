{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Appwrite Helm Chart Values",
  "description": "Configuration for Appwrite self-hosted backend-as-a-service platform",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource names"
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to every resource created by this chart"
    },
    "image": {
      "type": "object",
      "description": "Appwrite server container image",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "console": {
      "type": "object",
      "description": "Appwrite console image settings",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries"
    },
    "appwrite": {
      "type": "object",
      "description": "Appwrite application configuration",
      "properties": {
        "locale": { "type": "string" },
        "domain": { "type": "string" },
        "openSslKeyV1": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretOpenSslKey": { "type": "string" },
        "existingSecretJwtKey": { "type": "string" },
        "logging": { "type": "object" },
        "smtp": { "type": "object" },
        "usageStats": { "type": "string", "enum": ["enabled", "disabled"] },
        "graphql": { "type": "string", "enum": ["enabled", "disabled"] },
        "functions": { "type": "object" },
        "storage": { "type": "object" },
        "extraEnv": { "type": "array" }
      }
    },
    "api": {
      "type": "object",
      "description": "API server settings",
      "properties": {
        "replicaCount": { "type": "integer" },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" }
      }
    },
    "realtime": {
      "type": "object",
      "description": "Realtime server settings",
      "properties": {
        "replicaCount": { "type": "integer" },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "podAnnotations": { "type": "object" }
      }
    },
    "workers": {
      "type": "object",
      "description": "Worker deployment settings"
    },
    "schedulers": {
      "type": "object",
      "description": "Scheduler deployment settings"
    },
    "maintenance": {
      "type": "object",
      "description": "Maintenance task settings"
    },
    "tasks": {
      "type": "object",
      "description": "Background task settings"
    },
    "database": {
      "type": "object",
      "description": "Database connection settings",
      "properties": {
        "mode": { "type": "string", "enum": ["auto", "external"] },
        "external": { "type": "object" }
      }
    },
    "mariadb": {
      "type": "object",
      "description": "MariaDB subchart configuration"
    },
    "cache": {
      "type": "object",
      "description": "Cache (Redis) connection settings",
      "properties": {
        "mode": { "type": "string", "enum": ["auto", "external"] },
        "external": { "type": "object" }
      }
    },
    "redis": {
      "type": "object",
      "description": "Redis subchart configuration"
    },
    "persistence": {
      "type": "object",
      "description": "Shared PVC configuration for Appwrite data"
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration"
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer" },
        "annotations": { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration"
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer" },
    "extraEnv": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" }
  }
}
