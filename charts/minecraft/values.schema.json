{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Minecraft Server Helm Chart Values",
  "description": "Configuration values for the Minecraft Server Helm chart using itzg/minecraft-server. Supports Vanilla, Paper, Spigot, Forge, Fabric, Quilt, and more.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource names",
      "default": ""
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to every resource created by this chart"
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository",
          "default": "docker.io/itzg/minecraft-server"
        },
        "tag": {
          "type": "string",
          "description": "Container image tag (defaults to appVersion; use java21 for LTS)",
          "default": ""
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": {
        "type": "object"
      }
    },
    "server": {
      "type": "object",
      "description": "Minecraft server configuration",
      "additionalProperties": false,
      "properties": {
        "eula": {
          "type": "boolean",
          "description": "Accept the Minecraft EULA (required, must be true)",
          "default": true
        },
        "type": {
          "type": "string",
          "description": "Server type",
          "enum": ["VANILLA", "PAPER", "SPIGOT", "BUKKIT", "FORGE", "FABRIC", "QUILT", "FTBA", "CURSEFORGE", "MODRINTH", "AUTO_CURSEFORGE"],
          "default": "VANILLA"
        },
        "version": {
          "type": "string",
          "description": "Minecraft version (LATEST, SNAPSHOT, or specific like 1.21.4)",
          "default": "LATEST"
        },
        "motd": {
          "type": "string",
          "description": "Message of the day displayed in the server list",
          "default": "A Minecraft Server powered by HelmForge"
        },
        "difficulty": {
          "type": "string",
          "description": "Game difficulty",
          "enum": ["peaceful", "easy", "normal", "hard"],
          "default": "normal"
        },
        "gameMode": {
          "type": "string",
          "description": "Default game mode",
          "enum": ["survival", "creative", "adventure", "spectator"],
          "default": "survival"
        },
        "maxPlayers": {
          "type": "integer",
          "description": "Maximum number of concurrent players",
          "default": 20
        },
        "viewDistance": {
          "type": "integer",
          "description": "View distance in chunks (lower improves performance)",
          "default": 10
        },
        "simulationDistance": {
          "type": "integer",
          "description": "Simulation distance in chunks",
          "default": 10
        },
        "seed": {
          "type": "string",
          "description": "World seed (leave empty for random)",
          "default": ""
        },
        "worldSaveName": {
          "type": "string",
          "description": "World name (directory under /data)",
          "default": "world"
        },
        "levelType": {
          "type": "string",
          "description": "Level type",
          "enum": ["DEFAULT", "FLAT", "LARGEBIOMES", "AMPLIFIED", "CUSTOMIZED"],
          "default": "DEFAULT"
        },
        "pvp": {
          "type": "boolean",
          "description": "Enable player vs player combat",
          "default": true
        },
        "allowNether": {
          "type": "boolean",
          "description": "Enable the Nether dimension",
          "default": true
        },
        "allowFlight": {
          "type": "boolean",
          "description": "Allow flight (required for some mods)",
          "default": false
        },
        "enableCommandBlock": {
          "type": "boolean",
          "description": "Enable command blocks",
          "default": false
        },
        "forceGameMode": {
          "type": "boolean",
          "description": "Force players into the default game mode on join",
          "default": false
        },
        "hardcore": {
          "type": "boolean",
          "description": "Enable hardcore mode (permanent death)",
          "default": false
        },
        "spawnProtection": {
          "type": "integer",
          "description": "Spawn protection radius (0 to disable)",
          "default": 16
        },
        "port": {
          "type": "integer",
          "description": "Server port for Java Edition clients",
          "default": 25565
        },
        "extraProperties": {
          "type": "object",
          "description": "Extra server.properties entries as key-value pairs"
        },
        "extraEnv": {
          "type": "array",
          "description": "Additional environment variables for the server container",
          "items": {
            "type": "object"
          }
        },
        "extraArgs": {
          "type": "string",
          "description": "Additional arguments passed to the server JAR",
          "default": ""
        }
      }
    },
    "jvm": {
      "type": "object",
      "description": "JVM and performance configuration",
      "additionalProperties": false,
      "properties": {
        "memory": {
          "type": "string",
          "description": "JVM memory allocation (sets both -Xms and -Xmx)",
          "default": "1G"
        },
        "initMemory": {
          "type": "string",
          "description": "Override initial heap size independently",
          "default": ""
        },
        "maxMemory": {
          "type": "string",
          "description": "Override maximum heap size independently",
          "default": ""
        },
        "useAikarFlags": {
          "type": "boolean",
          "description": "Use Aikar's optimized GC flags (recommended for production)",
          "default": false
        },
        "jvmOpts": {
          "type": "string",
          "description": "Additional JVM options (space-delimited)",
          "default": ""
        },
        "xxOpts": {
          "type": "string",
          "description": "Additional -XX JVM options",
          "default": ""
        }
      }
    },
    "auth": {
      "type": "object",
      "description": "Authentication and access control",
      "additionalProperties": false,
      "properties": {
        "onlineMode": {
          "type": "boolean",
          "description": "Enable Mojang online authentication (set to false for offline/proxy mode)",
          "default": true
        },
        "whitelist": {
          "type": "string",
          "description": "Comma-separated list of whitelisted player names or UUIDs",
          "default": ""
        },
        "enforceWhitelist": {
          "type": "boolean",
          "description": "Enforce whitelist immediately when changed",
          "default": false
        },
        "ops": {
          "type": "string",
          "description": "Comma-separated list of operator (admin) player names or UUIDs",
          "default": ""
        }
      }
    },
    "geyser": {
      "type": "object",
      "description": "GeyserMC cross-play configuration (Bedrock clients)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable GeyserMC plugin for Bedrock cross-play",
          "default": false
        },
        "port": {
          "type": "integer",
          "description": "Bedrock listener port",
          "default": 19132
        }
      }
    },
    "rcon": {
      "type": "object",
      "description": "RCON remote console configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable RCON remote administration",
          "default": true
        },
        "port": {
          "type": "integer",
          "description": "RCON port",
          "default": 25575
        },
        "password": {
          "type": "string",
          "description": "RCON password (auto-generated if empty and no existingSecret)",
          "default": ""
        },
        "existingSecret": {
          "type": "string",
          "description": "Use an existing secret for the RCON password",
          "default": ""
        },
        "existingSecretKey": {
          "type": "string",
          "description": "Key in the existing secret that contains the RCON password",
          "default": "rcon-password"
        },
        "serviceEnabled": {
          "type": "boolean",
          "description": "Expose RCON as a separate Service",
          "default": false
        },
        "serviceType": {
          "type": "string",
          "description": "RCON service type (keep ClusterIP for security)",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistent storage configuration for server data (/data)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable persistent storage for server data (/data)",
          "default": true
        },
        "storageClass": {
          "type": "string",
          "description": "Storage class (leave empty for cluster default)",
          "default": ""
        },
        "accessMode": {
          "type": "string",
          "description": "Access mode for the PVC",
          "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany"],
          "default": "ReadWriteOnce"
        },
        "size": {
          "type": "string",
          "description": "Size of the persistent volume",
          "default": "10Gi"
        },
        "existingClaim": {
          "type": "string",
          "description": "Use an existing PVC instead of creating one",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the PVC"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory requests/limits for the server container"
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context",
      "properties": {
        "fsGroup": {
          "type": "integer",
          "description": "Group ID for volume ownership",
          "default": 1000
        }
      }
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context",
      "properties": {
        "runAsUser": {
          "type": "integer",
          "description": "User ID for the server process",
          "default": 1000
        },
        "runAsGroup": {
          "type": "integer",
          "description": "Group ID for the server process",
          "default": 1000
        },
        "allowPrivilegeEscalation": {
          "type": "boolean",
          "description": "Prevent privilege escalation",
          "default": false
        }
      }
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe configuration (recommended for slow-loading modpacks)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable startup probe (recommended for slow-loading modpacks)",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer",
          "description": "Initial delay before first check",
          "default": 30
        },
        "periodSeconds": {
          "type": "integer",
          "description": "Interval between checks",
          "default": 10
        },
        "timeoutSeconds": {
          "type": "integer",
          "description": "Timeout per check",
          "default": 5
        },
        "failureThreshold": {
          "type": "integer",
          "description": "Number of failures before the container is restarted",
          "default": 30
        }
      }
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable liveness probe",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer",
          "default": 0
        },
        "periodSeconds": {
          "type": "integer",
          "default": 15
        },
        "timeoutSeconds": {
          "type": "integer",
          "default": 5
        },
        "failureThreshold": {
          "type": "integer",
          "default": 3
        }
      }
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable readiness probe",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer",
          "default": 0
        },
        "periodSeconds": {
          "type": "integer",
          "default": 10
        },
        "timeoutSeconds": {
          "type": "integer",
          "default": 5
        },
        "failureThreshold": {
          "type": "integer",
          "default": 3
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Kubernetes Service configuration for the game port",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for the game port",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "LoadBalancer"
        },
        "port": {
          "type": "integer",
          "description": "Game port (must match server.port)",
          "default": 25565
        },
        "nodePort": {
          "type": ["string", "integer"],
          "description": "Node port (only used when service.type is NodePort)",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the game service"
        },
        "ipFamilyPolicy": {
          "type": ["string", "null"],
          "description": "Dual-stack ipFamilyPolicy (GR-058)",
          "enum": [null, "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Dual-stack ipFamilies (GR-058)",
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] },
          "maxItems": 2
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a dedicated ServiceAccount",
          "default": false
        },
        "name": {
          "type": "string",
          "description": "Name override (auto-generated if empty)",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the ServiceAccount"
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Prometheus metrics via mc-monitor sidecar",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Prometheus metrics via mc-monitor sidecar",
          "default": false
        },
        "image": {
          "type": "object",
          "description": "mc-monitor image configuration",
          "properties": {
            "repository": {
              "type": "string",
              "description": "mc-monitor image repository",
              "default": "docker.io/itzg/mc-monitor"
            },
            "tag": {
              "type": "string",
              "description": "mc-monitor image tag",
              "default": "0.16.1"
            },
            "pullPolicy": {
              "type": "string",
              "description": "mc-monitor pull policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "port": {
          "type": "integer",
          "description": "Port for the Prometheus metrics endpoint",
          "default": 8080
        },
        "serviceMonitor": {
          "type": "object",
          "description": "ServiceMonitor for Prometheus Operator",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor resource",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval",
              "default": "30s"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the ServiceMonitor"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Backup CronJob configuration (compressed archive + S3 upload)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable scheduled backups to S3-compatible storage",
          "default": false
        },
        "schedule": {
          "type": "string",
          "description": "Cron schedule for backups (default: daily at 04:00 UTC)",
          "default": "0 4 * * *"
        },
        "suspend": {
          "type": "boolean",
          "description": "Suspend the CronJob without deleting it",
          "default": false
        },
        "concurrencyPolicy": {
          "type": "string",
          "description": "Concurrency policy",
          "enum": ["Forbid", "Replace", "Allow"],
          "default": "Forbid"
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "description": "Number of successful job records to keep",
          "default": 3
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "description": "Number of failed job records to keep",
          "default": 3
        },
        "backoffLimit": {
          "type": "integer",
          "description": "Maximum retries per backup job",
          "default": 1
        },
        "archivePrefix": {
          "type": "string",
          "description": "Prefix for backup archive filenames",
          "default": "minecraft"
        },
        "excludes": {
          "type": "string",
          "description": "Directories to exclude from the backup archive (space-separated)",
          "default": "*.jar cache logs"
        },
        "images": {
          "type": "object",
          "description": "Container images used by the backup job",
          "properties": {
            "worker": {
              "type": "string",
              "description": "Image used for RCON commands and tar archiving (must have sh, tar, and rcon-cli)",
              "default": "docker.io/itzg/minecraft-server:2026.4.2"
            },
            "uploader": {
              "type": "string",
              "description": "Image used for S3 upload (MinIO client)",
              "default": "docker.io/minio/mc:RELEASE.2025-04-08T15-18-23Z"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for backup containers"
        },
        "s3": {
          "type": "object",
          "description": "S3-compatible storage configuration",
          "additionalProperties": false,
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "S3-compatible endpoint URL (e.g., https://s3.amazonaws.com, https://minio.example.com)",
              "default": ""
            },
            "bucket": {
              "type": "string",
              "description": "Target bucket name",
              "default": ""
            },
            "prefix": {
              "type": "string",
              "description": "Key prefix within the bucket",
              "default": "minecraft"
            },
            "createBucketIfNotExists": {
              "type": "boolean",
              "description": "Auto-create the bucket if it does not exist",
              "default": true
            },
            "existingSecret": {
              "type": "string",
              "description": "Use an existing secret for S3 credentials",
              "default": ""
            },
            "existingSecretAccessKeyKey": {
              "type": "string",
              "description": "Key in the existing secret for the access key",
              "default": "access-key"
            },
            "existingSecretSecretKeyKey": {
              "type": "string",
              "description": "Key in the existing secret for the secret key",
              "default": "secret-key"
            },
            "accessKey": {
              "type": "string",
              "description": "Inline S3 access key (ignored when existingSecret is set)",
              "default": ""
            },
            "secretKey": {
              "type": "string",
              "description": "Inline S3 secret key (ignored when existingSecret is set)",
              "default": ""
            }
          }
        }
      }
    },
    "mods": {
      "type": "object",
      "description": "Mods and plugins configuration",
      "additionalProperties": false,
      "properties": {
        "modrinthProjects": {
          "type": "string",
          "description": "Modrinth project slugs or IDs (comma-separated)",
          "default": ""
        },
        "curseforgeApiKey": {
          "type": "string",
          "description": "CurseForge API key (required for CurseForge downloads)",
          "default": ""
        },
        "autoCurseforgeSlug": {
          "type": "string",
          "description": "Auto CurseForge modpack slug (requires server.type: AUTO_CURSEFORGE)",
          "default": ""
        },
        "spigetResources": {
          "type": "string",
          "description": "Spiget resource IDs for Bukkit/Spigot plugins (comma-separated)",
          "default": ""
        },
        "downloadUrls": {
          "type": "string",
          "description": "URLs to download plugins or mods from (newline-separated)",
          "default": ""
        }
      }
    },
    "resourcePack": {
      "type": "object",
      "description": "Server resource pack configuration",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "URL to a server resource pack",
          "default": ""
        },
        "sha1": {
          "type": "string",
          "description": "SHA-1 hash of the resource pack for verification",
          "default": ""
        },
        "enforce": {
          "type": "boolean",
          "description": "Force clients to accept the resource pack",
          "default": false
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod scheduling"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints",
      "items": {
        "type": "object"
      }
    },
    "priorityClassName": {
      "type": "string",
      "description": "Priority class name",
      "default": ""
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Grace period for server shutdown (seconds, allow time for save-all)",
      "default": 120
    },
    "podLabels": {
      "type": "object",
      "description": "Additional labels for the pod"
    },
    "podAnnotations": {
      "type": "object",
      "description": "Additional annotations for the pod"
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts for the server container",
      "items": {
        "type": "object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes for the pod",
      "items": {
        "type": "object"
      }
    },
    "extraManifests": {
      "type": "array",
      "description": "Extra Kubernetes manifests to deploy alongside the chart",
      "items": {
        "type": "object"
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator integration for RCON credentials",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "apiVersion": { "type": "string", "default": "external-secrets.io/v1" },
        "refreshInterval": { "type": "string", "default": "0" },
        "secretStoreRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"], "default": "SecretStore" }
          }
        },
        "target": {
          "type": "object",
          "properties": {
            "creationPolicy": { "type": "string", "enum": ["Owner", "Merge", "None", "Orphan"], "default": "Owner" }
          }
        },
        "data": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
