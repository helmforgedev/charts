{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Dolibarr Helm Chart Values",
  "description": "Configuration values for the Dolibarr ERP/CRM Helm chart. Uses the official dolibarr/dolibarr Docker image with MySQL subchart or external database support.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource names"
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to every resource created by this chart"
    },
    "image": {
      "type": "object",
      "description": "Dolibarr container image configuration",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository"
        },
        "tag": {
          "type": "string",
          "description": "Container image tag (defaults to appVersion)"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": {
        "type": "object"
      }
    },
    "dolibarr": {
      "type": "object",
      "description": "Dolibarr application configuration",
      "properties": {
        "siteUrl": {
          "type": "string",
          "description": "Full external URL of the site"
        },
        "companyName": {
          "type": "string",
          "description": "Company name for Dolibarr setup"
        },
        "companyCountryCode": {
          "type": "string",
          "description": "ISO country code for the company"
        },
        "auth": {
          "type": "string",
          "description": "Authentication method"
        },
        "enableModules": {
          "type": "string",
          "description": "Comma-separated list of modules to enable"
        },
        "installAuto": {
          "type": "boolean",
          "description": "Enable automatic installation on first run"
        },
        "initDemo": {
          "type": "boolean",
          "description": "Initialize with demo data"
        },
        "prod": {
          "type": "boolean",
          "description": "Enable production mode"
        },
        "timezone": {
          "type": "string",
          "description": "Application timezone"
        },
        "extraEnv": {
          "type": "array",
          "description": "Additional environment variables for the container",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "admin": {
      "type": "object",
      "description": "Admin credentials configuration",
      "properties": {
        "login": {
          "type": "string",
          "description": "Admin username"
        },
        "password": {
          "type": "string",
          "description": "Admin password"
        },
        "existingSecret": {
          "type": "string",
          "description": "Existing secret containing the admin password"
        },
        "existingSecretPasswordKey": {
          "type": "string",
          "description": "Key in the existing secret for the admin password"
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "Runtime configuration",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Existing secret containing the instance unique ID"
        },
        "existingSecretInstanceUniqueIdKey": {
          "type": "string",
          "description": "Key in the existing secret for the instance unique ID"
        },
        "instanceUniqueId": {
          "type": "string",
          "description": "Instance unique identifier"
        }
      }
    },
    "database": {
      "type": "object",
      "description": "Database configuration",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Database mode selection",
          "enum": ["auto", "external", "mysql"]
        },
        "external": {
          "type": "object",
          "description": "External database configuration",
          "properties": {
            "host": {
              "type": "string",
              "description": "External database hostname"
            },
            "port": {
              "type": "integer",
              "description": "External database port"
            },
            "name": {
              "type": "string",
              "description": "Database name"
            },
            "username": {
              "type": "string",
              "description": "Database username"
            },
            "password": {
              "type": "string",
              "description": "Database password"
            },
            "existingSecret": {
              "type": "string",
              "description": "Existing secret for the database password"
            },
            "existingSecretPasswordKey": {
              "type": "string",
              "description": "Key in the existing secret for the database password"
            },
            "ssl": {
              "type": "boolean",
              "description": "Enable SSL for database connection"
            }
          }
        }
      }
    },
    "mysql": {
      "type": "object",
      "description": "MySQL subchart configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Deploy MySQL as a subchart"
        },
        "architecture": {
          "type": "string",
          "description": "MySQL architecture",
          "enum": ["standalone", "replication"]
        },
        "auth": {
          "type": "object",
          "description": "MySQL authentication",
          "properties": {
            "database": {
              "type": "string",
              "description": "Database name created on first run"
            },
            "username": {
              "type": "string",
              "description": "Database username created on first run"
            },
            "password": {
              "type": "string",
              "description": "Database password"
            },
            "rootPassword": {
              "type": "string",
              "description": "Root password"
            }
          }
        },
        "primary": {
          "type": "object",
          "description": "MySQL primary configuration",
          "properties": {
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable persistence for MySQL data"
                },
                "size": {
                  "type": "string",
                  "description": "PVC size for MySQL"
                }
              }
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistence configuration for Dolibarr volumes",
      "properties": {
        "documents": {
          "type": "object",
          "description": "Documents volume persistence",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable persistence for documents"
            },
            "storageClass": {
              "type": "string",
              "description": "Storage class"
            },
            "accessMode": {
              "type": "string",
              "description": "Access mode for the PVC"
            },
            "size": {
              "type": "string",
              "description": "Size of the persistent volume"
            },
            "existingClaim": {
              "type": "string",
              "description": "Use an existing PVC"
            },
            "annotations": {
              "type": "object",
              "description": "Annotations for the PVC"
            }
          }
        },
        "custom": {
          "type": "object",
          "description": "Custom modules volume persistence",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable persistence for custom modules"
            },
            "storageClass": {
              "type": "string",
              "description": "Storage class"
            },
            "accessMode": {
              "type": "string",
              "description": "Access mode for the PVC"
            },
            "size": {
              "type": "string",
              "description": "Size of the persistent volume"
            },
            "existingClaim": {
              "type": "string",
              "description": "Use an existing PVC"
            },
            "annotations": {
              "type": "object",
              "description": "Annotations for the PVC"
            }
          }
        }
      }
    },
    "php": {
      "type": "object",
      "description": "PHP configuration overrides",
      "properties": {
        "memoryLimit": {
          "type": "string",
          "description": "PHP memory limit"
        },
        "uploadMaxFilesize": {
          "type": "string",
          "description": "Maximum upload file size"
        },
        "postMaxSize": {
          "type": "string",
          "description": "Maximum POST size"
        },
        "maxExecutionTime": {
          "type": "string",
          "description": "Maximum execution time in seconds"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory requests/limits for the Dolibarr container"
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context"
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context"
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable startup probe"
        },
        "path": {
          "type": "string",
          "description": "HTTP GET probe path"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "description": "Initial delay before probe starts"
        },
        "periodSeconds": {
          "type": "integer",
          "description": "Probe check interval"
        },
        "timeoutSeconds": {
          "type": "integer",
          "description": "Probe timeout"
        },
        "failureThreshold": {
          "type": "integer",
          "description": "Failures before marking unhealthy"
        }
      }
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable liveness probe"
        },
        "path": {
          "type": "string",
          "description": "HTTP GET probe path"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "description": "Initial delay before probe starts"
        },
        "periodSeconds": {
          "type": "integer",
          "description": "Probe check interval"
        },
        "timeoutSeconds": {
          "type": "integer",
          "description": "Probe timeout"
        },
        "failureThreshold": {
          "type": "integer",
          "description": "Failures before marking unhealthy"
        }
      }
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable readiness probe"
        },
        "path": {
          "type": "string",
          "description": "HTTP GET probe path"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "description": "Initial delay before probe starts"
        },
        "periodSeconds": {
          "type": "integer",
          "description": "Probe check interval"
        },
        "timeoutSeconds": {
          "type": "integer",
          "description": "Probe timeout"
        },
        "failureThreshold": {
          "type": "integer",
          "description": "Failures before marking unhealthy"
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "description": "HTTP service port"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the Service"
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ingress"
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name"
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations"
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts",
          "items": {
            "type": "object"
          }
        },
        "tls": {
          "type": "array",
          "description": "Ingress TLS configuration",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "Service account configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a dedicated ServiceAccount"
        },
        "name": {
          "type": "string",
          "description": "Name override"
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the ServiceAccount"
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod scheduling"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints",
      "items": {
        "type": "object"
      }
    },
    "priorityClassName": {
      "type": "string",
      "description": "Priority class name"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Grace period for shutdown in seconds"
    },
    "podLabels": {
      "type": "object",
      "description": "Additional labels for the pod"
    },
    "podAnnotations": {
      "type": "object",
      "description": "Additional annotations for the pod"
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts for the container",
      "items": {
        "type": "object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes for the pod",
      "items": {
        "type": "object"
      }
    },
    "extraManifests": {
      "type": "array",
      "description": "Extra Kubernetes manifests to deploy alongside the chart",
      "items": {
        "type": "object"
      }
    }
  }
}
