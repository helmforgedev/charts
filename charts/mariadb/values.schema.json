{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "MariaDB Helm Chart Values",
  "description": "Configuration for MariaDB Helm chart with standalone and replication modes",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "architecture": {
      "type": "string",
      "description": "MariaDB deployment mode",
      "enum": ["standalone", "replication"]
    },
    "nameOverride": {
      "type": "string",
      "description": "Override chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override full release name"
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to all resources"
    },
    "clusterDomain": {
      "type": "string",
      "description": "Kubernetes cluster domain"
    },
    "image": {
      "type": "object",
      "description": "MariaDB container image",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets"
    },
    "auth": {
      "type": "object",
      "description": "MariaDB authentication settings",
      "properties": {
        "rootPassword": { "type": "string" },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "replicationUsername": { "type": "string" },
        "replicationPassword": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretRootPasswordKey": { "type": "string" },
        "existingSecretUserPasswordKey": { "type": "string" },
        "existingSecretReplicationPasswordKey": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "description": "MariaDB configuration",
      "properties": {
        "preset": { "type": "string", "enum": ["none", "small", "medium", "large", "oltp", "read-heavy", "analytics"] },
        "myCnf": { "type": "string" }
      }
    },
    "initdb": {
      "type": "object",
      "description": "Initialization scripts",
      "properties": {
        "scripts": { "type": "object" },
        "existingConfigMap": { "type": "string" }
      }
    },
    "standalone": {
      "type": "object",
      "description": "Standalone mode settings"
    },
    "replication": {
      "type": "object",
      "description": "Replication mode settings"
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer" },
        "metricsPort": { "type": "integer" },
        "annotations": { "type": "object" },
        "sourceAnnotations": { "type": "object" },
        "replicasAnnotations": { "type": "object" }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Prometheus metrics exporter"
    },
    "tls": {
      "type": "object",
      "description": "TLS configuration"
    },
    "backup": {
      "type": "object",
      "description": "S3 backup CronJob configuration"
    },
    "networkPolicy": {
      "type": "object",
      "description": "NetworkPolicy configuration"
    },
    "pdb": {
      "type": "object",
      "description": "PodDisruptionBudget configuration"
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration"
    },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "podLabels": { "type": "object" },
    "podAnnotations": { "type": "object" },
    "annotations": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer" },
    "extraEnv": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" }
  }
}
