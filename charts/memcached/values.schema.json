{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://helmforge.dev/schemas/memcached/values.schema.json",
  "title": "HelmForge Memcached values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object", "additionalProperties": true },
    "clusterDomain": { "type": "string", "minLength": 1 },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "headlessService": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "annotations": { "type": "object", "additionalProperties": true }
      }
    },
    "resources": { "type": "object", "additionalProperties": true },
    "podSecurityContext": { "type": "object", "additionalProperties": true },
    "securityContext": { "type": "object", "additionalProperties": true },
    "podLabels": { "type": "object", "additionalProperties": true },
    "podAnnotations": { "type": "object", "additionalProperties": true },
    "priorityClassName": { "type": "string" },
    "nodeSelector": { "type": "object", "additionalProperties": true },
    "tolerations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "affinity": { "type": "object", "additionalProperties": true },
    "topologySpreadConstraints": {
      "type": "array",
      "items": { "type": "object" }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "extraEnv": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraEnvFrom": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraInitContainers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraContainers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraManifests": {
      "type": "array",
      "items": { "type": "object" }
    },
    "architecture": {
      "type": "string",
      "enum": ["standalone", "distributed"],
      "description": "Deployment topology. standalone creates one pod; distributed creates independent cache nodes."
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1, "default": "1.6.42" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "memcached": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "memoryLimitMB": { "type": "integer", "minimum": 1 },
        "maxConnections": { "type": "integer", "minimum": 1 },
        "threads": { "type": "integer", "minimum": 1 },
        "maxItemSize": { "type": "string", "minLength": 1 },
        "protocol": { "type": "string", "enum": ["auto", "ascii", "binary"] },
        "listenAddress": { "type": "string", "minLength": 1 },
        "udpPort": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "disableFlushAll": { "type": "boolean" },
        "disableEvictions": { "type": "boolean" },
        "disableCas": { "type": "boolean" },
        "disableWatch": { "type": "boolean" },
        "disableDumping": { "type": "boolean" },
        "extendedOptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "extraArgs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["ascii", "sasl"] },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "existingSecret": { "type": "string" },
        "authFileKey": { "type": "string", "minLength": 1 },
        "sasl": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mountPath": { "type": "string", "minLength": 1 },
            "configKey": { "type": "string", "minLength": 1 },
            "databaseKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshInterval": { "type": "string" },
        "secretStoreRef": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"] }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "creationPolicy": { "type": "string" }
          }
        },
        "data": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "certKey": { "type": "string", "minLength": 1 },
        "keyKey": { "type": "string", "minLength": 1 },
        "caKey": { "type": "string" },
        "verifyMode": { "type": "string" },
        "minVersion": { "type": "string" },
        "volumePermissions": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "extstore": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 },
        "size": { "type": "string", "minLength": 1 },
        "pageSizeMB": { "type": "integer", "minimum": 1 },
        "wbufSizeMB": { "type": "integer", "minimum": 1 },
        "threads": { "type": "integer", "minimum": 1 },
        "itemSizeBytes": { "type": "integer", "minimum": 1 },
        "persistence": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "size": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "ipFamilyPolicy": { "type": "string" },
        "ipFamilies": {
          "type": "array",
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] },
          "maxItems": 2
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "memcachedTLS": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "insecureSkipVerify": { "type": "boolean" },
            "serverName": { "type": "string" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "prometheusRule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "rules": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "egress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "allowSameNamespace": { "type": "boolean" },
            "allowDNS": { "type": "boolean" },
            "allowHTTPS": { "type": "boolean" }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    }
  }
}
