{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Poznote Helm Chart Values",
  "description": "Values for the poznote Helm chart",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name"
    },
    "commonLabels": {
      "type": "object",
      "description": "Extra labels applied to all objects"
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "properties": {
        "repository": {
          "type": "string",
          "description": "Image repository"
        },
        "tag": {
          "type": "string",
          "description": "Image tag"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets"
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of replicas",
      "minimum": 1,
      "default": 1
    },
    "app": {
      "type": "object",
      "description": "Application configuration",
      "properties": {
        "port": {
          "type": "integer",
          "description": "HTTP port",
          "minimum": 1,
          "maximum": 65535
        },
        "timezone": {
          "type": "string",
          "description": "Container timezone"
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug mode"
        },
        "command": {
          "type": "array",
          "description": "Command override"
        },
        "args": {
          "type": "array",
          "description": "Arguments override"
        },
        "env": {
          "type": "array",
          "description": "Additional environment variables"
        },
        "envFrom": {
          "type": "array",
          "description": "Additional envFrom sources"
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Secret configuration",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Existing Secret name"
        },
        "oidcClientIdKey": {
          "type": "string",
          "description": "Key for OIDC client ID in Secret"
        },
        "oidcClientId": {
          "type": "string",
          "description": "Inline OIDC client ID"
        },
        "oidcClientSecretKey": {
          "type": "string",
          "description": "Key for OIDC client secret in Secret"
        },
        "oidcClientSecret": {
          "type": "string",
          "description": "Inline OIDC client secret"
        }
      }
    },
    "poznote": {
      "type": "object",
      "description": "Poznote-specific configuration",
      "properties": {
        "oidc": {
          "type": "object",
          "properties": {
            "disableNormalLogin": {
              "type": "boolean",
              "description": "Disable local login and force SSO-only"
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistence configuration",
      "properties": {
        "data": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable data persistence"
            },
            "size": {
              "type": "string",
              "description": "PVC size"
            },
            "storageClass": {
              "type": "string",
              "description": "Storage class"
            },
            "accessModes": {
              "type": "array",
              "description": "PVC access modes"
            },
            "existingClaim": {
              "type": "string",
              "description": "Existing PVC name"
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a ServiceAccount"
        },
        "name": {
          "type": "string",
          "description": "ServiceAccount name"
        },
        "annotations": {
          "type": "object",
          "description": "ServiceAccount annotations"
        },
        "automountServiceAccountToken": {
          "type": "boolean",
          "description": "Mount SA token"
        }
      }
    },
    "service": {
      "type": "object",
      "description": "Service configuration",
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "description": "Service port",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "type": "object",
          "description": "Service annotations"
        },
        "ipFamilyPolicy": {
          "type": "string",
          "description": "IP family policy"
        },
        "ipFamilies": {
          "type": "array",
          "description": "IP families"
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Ingress"
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name"
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations"
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts"
        },
        "tls": {
          "type": "array",
          "description": "Ingress TLS"
        }
      }
    },
    "gatewayAPI": {
      "type": "object",
      "description": "Gateway API configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Gateway API HTTPRoute"
        },
        "httpRoutes": {
          "type": "array",
          "description": "HTTPRoute definitions"
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ExternalSecret resources"
        },
        "apiVersion": {
          "type": "string",
          "description": "ExternalSecret API version"
        },
        "refreshInterval": {
          "type": "string",
          "description": "Default sync interval"
        },
        "items": {
          "type": "array",
          "description": "ExternalSecret definitions"
        }
      }
    },
    "pdb": {
      "type": "object",
      "description": "PodDisruptionBudget configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a PDB"
        },
        "minAvailable": {
          "type": "integer",
          "description": "Minimum available pods",
          "minimum": 0
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "description": "NetworkPolicy configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Create a NetworkPolicy"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "Container resources"
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations"
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules"
    },
    "extraManifests": {
      "type": "array",
      "description": "Additional manifests"
    }
  }
}
