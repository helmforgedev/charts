{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://helmforge.dev/schemas/zookeeper/values.schema.json",
  "title": "HelmForge ZooKeeper values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "allowEvenReplicas": { "type": "boolean" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "namespaceOverride": { "type": "string" },
    "clusterDomain": { "type": "string", "minLength": 1 },
    "commonLabels": { "type": "object", "additionalProperties": true },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "zookeeper": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "clientPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "followerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "electionPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "tickTime": { "type": "integer", "minimum": 1 },
        "initLimit": { "type": "integer", "minimum": 1 },
        "syncLimit": { "type": "integer", "minimum": 1 },
        "maxClientCnxns": { "type": "integer", "minimum": 0 },
        "standaloneEnabled": { "type": "boolean" },
        "adminServerEnabled": { "type": "boolean" },
        "adminServerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "autopurgeSnapRetainCount": { "type": "integer", "minimum": 3 },
        "autopurgePurgeInterval": { "type": "integer", "minimum": 0 },
        "fourLetterWordWhitelist": { "type": "string" },
        "extraConfig": { "type": "string" },
        "jvmFlags": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "client": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "existingSecret": { "type": "string" },
            "existingSecretJaasKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "client": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "existingSecret": { "type": "string" },
            "keystoreKey": { "type": "string", "minLength": 1 },
            "truststoreKey": { "type": "string", "minLength": 1 },
            "keystorePassword": { "type": "string" },
            "truststorePassword": { "type": "string" },
            "existingPasswordsSecret": { "type": "string" },
            "existingKeystorePasswordKey": { "type": "string", "minLength": 1 },
            "existingTruststorePasswordKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "annotations": { "type": "object", "additionalProperties": true },
        "ipFamilyPolicy": { "type": "string", "enum": ["", "SingleStack", "PreferDualStack", "RequireDualStack"] },
        "ipFamilies": {
          "type": "array",
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] },
          "maxItems": 2
        },
        "ports": { "type": "object", "additionalProperties": true }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "allowSameNamespace": { "type": "boolean" },
        "egress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowSameNamespace": { "type": "boolean" },
            "allowDns": { "type": "boolean" },
            "extra": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" } },
        "size": { "type": "string", "minLength": 1 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" }
          }
        },
        "prometheusRule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "rules": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object", "additionalProperties": true },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxUnavailable": { "type": ["integer", "string"] },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },
    "podSecurityContext": { "type": "object", "additionalProperties": true },
    "securityContext": { "type": "object", "additionalProperties": true },
    "resources": { "type": "object", "additionalProperties": true },
    "livenessProbe": { "type": "object", "additionalProperties": true },
    "readinessProbe": { "type": "object", "additionalProperties": true },
    "startupProbe": { "type": "object", "additionalProperties": true },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "updateStrategy": { "type": "object", "additionalProperties": true },
    "podLabels": { "type": "object", "additionalProperties": true },
    "podAnnotations": { "type": "object", "additionalProperties": true },
    "priorityClassName": { "type": "string" },
    "nodeSelector": { "type": "object", "additionalProperties": true },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object", "additionalProperties": true },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
    "extraEnv": { "type": "array", "items": { "type": "object" } },
    "extraEnvFrom": { "type": "array", "items": { "type": "object" } },
    "extraVolumes": { "type": "array", "items": { "type": "object" } },
    "extraVolumeMounts": { "type": "array", "items": { "type": "object" } },
    "extraInitContainers": { "type": "array", "items": { "type": "object" } },
    "extraContainers": { "type": "array", "items": { "type": "object" } },
    "extraManifests": { "type": "array", "items": { "type": "object" } },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "apiVersion": { "type": "string", "enum": ["external-secrets.io/v1"] },
        "refreshInterval": { "type": "string" },
        "secretStoreRef": { "type": "object", "additionalProperties": true },
        "target": { "type": "object", "additionalProperties": true },
        "data": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
